# Database
NUXT_DATABASE_URL=./data/hire-me.db

# Session password — MINIMUM 32 characters!
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_SESSION_PASSWORD=

# Access control — comma-separated emails allowed to login
# Example: NUXT_ALLOWED_EMAILS=admin@gmail.com,coworker@gmail.com
NUXT_ALLOWED_EMAILS=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Used for: login (optional) + Google Drive backup authorization
# Setup: https://console.cloud.google.com/ → APIs & Services → Credentials
#   → Create OAuth 2.0 Client ID (Web application)
#   → Authorized redirect URIs (add both):
#       http://localhost:3000/auth/google        ← for Google login
#       http://localhost:3000/auth/google-drive  ← for Drive backup
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
# Must match exactly one of the redirect URIs registered above
NUXT_OAUTH_GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google

# ─── Google Drive Backup (optional) ──────────────────────────────────────────
# 1. Enable Google Drive API: console.cloud.google.com → APIs & Services → Enable APIs
# 2. Create a folder on drive.google.com, copy ID from URL:
#    https://drive.google.com/drive/folders/<FOLDER_ID>
# 3. Set NUXT_GOOGLE_BACKUP_FOLDER_ID below
# 4. In the app: Settings → click "Підключити Google Drive" → authorize
NUXT_GOOGLE_BACKUP_FOLDER_ID=

# ─── Claude API ───────────────────────────────────────────────────────────────
# Optional — only needed for AI analysis feature
# Get key at: https://console.anthropic.com/
NUXT_ANTHROPIC_API_KEY=

# ─── Email IMAP ───────────────────────────────────────────────────────────────
# For ukr.net: use app-specific password (not your main password)
NUXT_IMAP_HOST=imap.ukr.net
NUXT_IMAP_PORT=993
NUXT_IMAP_USER=your@ukr.net
NUXT_IMAP_PASSWORD=

# ─── Telegram MTProto ─────────────────────────────────────────────────────────
# Create an app at https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── Legacy / optional ────────────────────────────────────────────────────────
# Google Drive MCP HTTP wrapper (optional)
NUXT_GOOGLE_DRIVE_MCP_URL=
# Telegram MCP HTTP wrapper (legacy, replaced by MTProto above)
NUXT_TELEGRAM_MCP_URL=

# Database
DATABASE_URL=./data/hire-me.db

# Auth — Google OAuth
# Create credentials at https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/auth/google
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Session password — MINIMUM 32 characters!
NUXT_SESSION_PASSWORD=

# Access control — comma-separated emails allowed to login
# Example: ALLOWED_EMAILS=admin@gmail.com,coworker@gmail.com
ALLOWED_EMAILS=

# Claude API
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Email IMAP (ukr.net)
IMAP_HOST=imap.ukr.net
IMAP_PORT=993
IMAP_USER=your@ukr.net
IMAP_PASSWORD=

# Google Drive MCP
GOOGLE_DRIVE_MCP_URL=https://drive.mcp.claude.com/mcp

# Telegram MCP HTTP wrapper
# Run a local HTTP wrapper that exposes Telegram MCP as REST:
# GET /dialog/:username → { messages: [{id, date, fromSelf, text}] }
TELEGRAM_MCP_URL=http://localhost:3001
